#include <iostream>
#include <string>
using namespace std;

int main()
{
    string text, pattern;

    cout << "Enter Text: ";
    cin >> text;

    cout << "Enter Pattern: ";
    cin >> pattern;

    int n = text.length();
    int m = pattern.length();

    int shift[27];
    for (int i = 0; i < 27; i++)
        shift[i] = m;

    for (int j = 0; j < m - 1; j++)
        shift[pattern[j]] = m - 1 - j;
    cout << "\nShift Table:\n";
    for (int i = 0; i < 27; i++)
    {
        if (shift[i] != m)
            cout << char(i) << " : " << shift[i] << endl;
    }

    int i = m - 1;
    int comparisons = 0;
    int alignments = 0;

    cout << "\n--- Matching Process ---\n";
    while (i <= n - 1)
    {
        alignments++;

        cout << "\nAlignment " << alignments << ":\n";
        cout << text << endl;
        for (int s = 0; s < i - (m - 1); s++)
            cout << " ";
        cout << pattern << endl;

        int k = 0;

        while (k <= m - 1 && pattern[m - 1 - k] == text[i - k])
        {
            comparisons++;
            k++;
        }


        if (k < m)
            comparisons++;

        if (k == m)
        {
            cout << "Pattern found at index: " << i - m + 1 << endl;
            cout << "Total Comparisons: " << comparisons << endl;
            cout << "Total Alignments: " << alignments << endl;
            return 0;
        }
        else
        {
            cout << "Mismatch at text[" << i << "] = " << text[i] << endl;
            cout << "Shift by: " << shift[text[i]] << endl;

            i = i + shift[text[i]];
        }
    }

    cout << "\nPattern not found\n";
    cout << "Total Comparisons: " << comparisons << endl;
    cout << "Total Alignments: " << alignments << endl;

    return 0;
}

