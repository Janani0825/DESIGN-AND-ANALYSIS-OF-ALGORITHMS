#include<iostream>
#include<cmath>
using namespace std;
struct Point {
   double x,y;
};
double bruteforceclosestpair(Point P[],int n)
{
   double d=INFINITY;
   for(int i=0;i<n-1;i++)
   {
      for(int j=i+1;j<n;j++)
      {
         double dist=sqrt((P[i].x-P[j].x)*(P[i].x-P[j].x)+(P[i].y-P[j].y)*
         (P[i].y-P[j].y));
         cout <<"Distance between P"<<i+1<<"("<<P[i].x<<","<<P[i].y<<")and
         P"<<j+1<<"("<<P[j].x<<","<<P[j].y<<")="<<dist<<endl;
         if (dist < d)
         {
            d=dist;
            cout<<"minimum distance="<<d<<endl;
         }
      }
   }
   return d;
}
int main() {
   int n;
   cout<<"Enter number of points:";
   cin>>n;
   Point P[n];
   cout<<"Enter Points(x y):"<<endl;
   for(int i=0;i<n;i++) {
      cin>>P[i].x>>P[i].y;
   }
   double result= bruteforceclosestpair(P,n);
   cout<<"Final Minimum distance:"<<result<<endl;
   return 0;
}

