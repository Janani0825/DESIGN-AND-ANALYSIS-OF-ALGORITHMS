#include<iostream>
#include<string>
using namespace std;

void bruteforce_visual(string T, string P) {
    int n = T.length();
    int m = P.length();
    int total_comparisons = 0;
    int total_alignments = 0;

    for (int i = 0; i <= n - m; i++) {
        total_alignments++;
        cout << "Pass " << i << ":" << endl;
        cout << "Text:    " << T << endl;
        cout << "Pattern: ";
        for (int k = 0; k < i; k++) cout << " ";
        cout << P << endl;

        cout << "Checks:  ";
        for (int k = 0; k < i; k++) cout << " ";

        int j = 0;
        while (j < m) {
            total_comparisons++; // Count every character check
            if (T[i + j] == P[j]) {
                cout << "|";
                j++;
            } else {
                cout << "X";
                break;
            }
        }
        cout << "\n" << endl;

        if (j == m) {
            cout << "Pattern found at index: " << i << endl;
            cout << "Number of alignments made: " << total_alignments << endl;
            cout << "Number of comparisons made: " << total_comparisons << endl;
            return;
        }
    }
    cout << "Pattern not found" << endl;
    cout << "Number of alignments made: " << total_alignments << endl;
    cout << "Number of comparisons made: " << total_comparisons << endl;
}

int main() {
    string T, P;
    cout << "Text: "; getline(cin, T);
    cout << "Pattern: "; getline(cin, P);
    cout << endl;
    bruteforce_visual(T, P);
    return 0;
}
