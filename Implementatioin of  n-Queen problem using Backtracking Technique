#include <iostream>
#include <vector>
#include <cmath>

using namespace std;

int x[20];

bool Place(int k, int i) {
    for (int j = 1; j <= k - 1; j++) {
        if ((x[j] == i) || (abs(x[j] - i) == abs(j - k))) {
            return false;
        }
    }
    return true;
}

void displaySolutionVector(int n) {
    cout << "Solution Vector: [ ";
    for (int i = 1; i <= n; i++) {
        cout << x[i] << " ";
    }
    cout << "]" << endl;
}

void printMatrix(int n) {
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            if (x[i] == j)
                cout << "Q ";
            else
                cout << ". ";
        }
        cout << endl;
    }
    cout << "-----------------" << endl;
}

void NQueens(int k, int n) {
    for (int i = 1; i <= n; i++) {
        if (Place(k, i)) {
            x[k] = i;
            if (k == n) {
                displaySolutionVector(n);
                printMatrix(n);
            } else {
                NQueens(k + 1, n);
            }
        }
    }
}

int main() {
    int n;
    cout << "Enter the number of queens (n): ";
    cin >> n;

    if (n > 0 && n < 20) {
        NQueens(1, n);
    } else {
        cout << "Please enter a valid number (1-19)." << endl;
    }

    return 0;
}
